# ── BMS 平台配置示例 ──
# 复制为 .env 并按环境填写。所有外部依赖均走环境变量，切换只改配置不改代码。

# ── 数据库（PostgreSQL 16 + pgvector；开发沙箱用 15）──
# 可用完整 DSN，或下方分项。
# PG_DSN=postgresql://bms:bms@127.0.0.1:5432/bms
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=bms
PG_PASSWORD=bms
PG_DB=bms

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379/0

# ── 文件存储 ──
DATA_DIR=/data/cases
FILE_RETENTION_DAYS=7
MAX_UPLOAD_MB=50
CLEANUP_INTERVAL_HOURS=24

# ── 队列与并发 ──
MAX_RUNNING=2
MAX_QUEUED=2

# ── 本地模型（OpenAI 兼容接口，vLLM）──
LLM_BASE_URL=http://10.7.5.237:5001/v1
LLM_MODEL=DeepSeek-V4-Flash
# TODO: 填入 vLLM 服务的 API Key
LLM_API_KEY=
LLM_MAX_INPUT_TOKENS=24000
LLM_MAX_OUTPUT_TOKENS=16000
LLM_TIMEOUT=600

# ── 嵌入模型（BGE-M3）──
EMBED_BASE_URL=http://10.7.5.237:5001/v1
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# ── 覆盖引擎 ──
COMBINATION_STRENGTH=pairwise
BVA_TOLERANCE_VOLTAGE_STATIC_MV=10
BVA_TOLERANCE_VOLTAGE_DYNAMIC_MV=30
BVA_TOLERANCE_CURRENT_MA=10
BVA_TOLERANCE_TEMPERATURE_C=1
